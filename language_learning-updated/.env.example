# ── PostgreSQL (main app database) ──────────────────────────────────────────
# Used by Drizzle ORM for lessons, users, quiz attempts, IELTS results, etc.
DATABASE_URL=postgresql://postgres:mo3taz501@localhost:5432/language_learning

# ── Session / JWT ────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret

# ── OAuth (production / staging) ─────────────────────────────────────────────
VITE_APP_ID=your-app-id
VITE_OAUTH_PORTAL_URL=https://your-oauth-server.com
OAUTH_SERVER_URL=https://your-oauth-server.com
OWNER_OPEN_ID=your-open-id

# ── IELTS Backend ─────────────────────────────────────────────────────────────
# The Express proxy in this app forwards /api/ielts-questions → IELTS_BACKEND_URL
# Run the ielts-backend separately (default port 3001)
IELTS_BACKEND_URL=http://localhost:3001

# ── SpeechBrain service ──────────────────────────────────────────────────────
# URL of the SpeechBrain Python service (run: cd speechbrain-service && uvicorn main:app --port 8000)
# The Express server proxies /api/sb-speech → SPEECHBRAIN_URL/speech
SPEECHBRAIN_URL=http://localhost:5000/evaluate-pronunciation

# ── Dev-only: skip OAuth on localhost ────────────────────────────────────────
# Set to any integer user ID that exists in your DB.
# Remove before deploying to production!
DEV_USER_ID=1

# ── Optional: AI features ─────────────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Llama lesson generation through OpenRouter.
# Prefer the server-only name. The backend also supports VITE_OPENROUTER_API_KEY
# for compatibility with older local env files.
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
LLAMA_MODEL=meta-llama/llama-3.1-70b-instruct

# ── Server port ───────────────────────────────────────────────────────────────
PORT=3000
